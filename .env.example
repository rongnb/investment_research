# Investment Research System Configuration

# Data Sources
TUSHARE_TOKEN=your_tushare_token_here
AKSHARE_TOKEN=your_akshare_token_here

# API Configuration
API_BASE_URL=https://api.investment-research.com
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=investment_research
DB_USER=root
DB_PASSWORD=password

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password

# Notifications
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_WECHAT_NOTIFICATIONS=False
ENABLE_SLACK_NOTIFICATIONS=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/investment_research.log

# Optimization Parameters
MAX_ASSET_COUNT=20
MIN_WEIGHT=0.01
MAX_WEIGHT=0.25
MIN_SAMPLE_SIZE=30
FORECAST_HORIZON=12
